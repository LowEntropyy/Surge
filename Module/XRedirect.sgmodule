#!name=XRedirect
#!desc=常用域名重定向

[URL Rewrite]
# Google 区域搜索域名跳转到 google.com，并用 gws_rd=cr 阻止地区确认跳转形成循环。
^https?:\/\/(?:www\.)?google\.(?!com(?:$|[\/:]))(?:[a-z]{2,3}\.)?[a-z]{2,3}(\/(?:search|webhp)\?[^#]+)$ https://www.google.com$1&gws_rd=cr 302
^https?:\/\/(?:www\.)?google\.(?!com(?:$|[\/:]))(?:[a-z]{2,3}\.)?[a-z]{2,3}(\/(?:search|webhp))\/?$ https://www.google.com$1?gws_rd=cr 302

# Google 中国域名与地图重定向，合并自 QingRex/LoonKissSurge Beta 模块。
^https?:\/\/(?:www\.)?(?:g|google)\.cn(.*)$ https://www.google.com$1 302
^https?:\/\/(?:ditu|maps)\.google\.cn(.*)$ https://maps.google.com$1 302



# ── 常用网站：HTTP 升级与主域名统一 ──

# AiCoin：aicoin.cn 当前无法稳定解析；若请求命中，则跳转到 AiCoin 官方唯一网站 www.aicoin.com。
^http:\/\/(?:www\.)?aicoin\.cn\/$ https://www.aicoin.com/ 302

# 京东：将 jd.com 与 www.jd.com 的 HTTP 请求升级到 HTTPS 官方主站。
^http:\/\/(?:www\.)?jd\.com\/ https://www.jd.com/ 302

# 小米：将 mi.com 与 www.mi.com 的 HTTP 请求升级到 HTTPS 官方主站。
^http:\/\/(?:www\.)?mi\.com\/ https://www.mi.com/ 302

# 苏宁：将 suning.com 与 www.suning.com 的 HTTP 请求升级到 HTTPS 主站。
^http:\/\/(?:www\.)?suning\.com\/ https://suning.com/ 302

# 淘宝：将 taobao.com 与 www.taobao.com 的 HTTP 请求升级到 HTTPS 主站。
^http:\/\/(?:www\.)?taobao\.com\/ https://taobao.com/ 302

# 1号店：将 yhd.com 与 www.yhd.com 的 HTTP 请求升级到 HTTPS 主站。
^http:\/\/(?:www\.)?yhd\.com\/ https://yhd.com/ 302

# 网易严选：将 you.163.com 的 HTTP 请求升级到 HTTPS。
^http:\/\/you\.163\.com\/ https://you.163.com/ 302



